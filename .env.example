# JWT Configuration
JWT_ACCESS_SECRETKEY=your-super-secret-access-key-change-this-in-production-at-least-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRETKEY=your-super-secret-refresh-key-change-this-in-production-at-least-32-chars
JWT_REFRESH_EXPIRES=7d

# Default Reset Password
RESET_PASSWORD=123456

# Frontend Client URL
CLIENT_URL=https://stack-fe.vercal.app

# Node Environment
NODE_ENV=development

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=aaa.0123@gmail.com
MAIL_PASS=abcd xyzt gwyp cwbl
MAIL_FROM=STACK APP

GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxx
